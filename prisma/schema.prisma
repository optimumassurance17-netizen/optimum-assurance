generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  raisonSociale         String?
  siret                String?
  adresse               String?
  codePostal            String?
  ville                 String?
  telephone             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  documents             Document[]
  userDocuments         UserDocument[]
  payments              Payment[]
  avenantFees           AvenantFee[]
  passwordResetTokens   PasswordResetToken[]
  resiliationRequests   ResiliationRequest[]
  clientNotes           ClientNote[]
  sinistres             Sinistre[]
  sepaSubscription      SepaSubscription?
  insuranceContracts    InsuranceContract[]
}

/// Cycle de vie assurance (plateforme SaaS — décennale | DO). DB : PostgreSQL (URL Supabase possible).
model InsuranceContract {
  id                 String   @id @default(cuid())
  contractNumber     String   @unique
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  productType        String
  clientName         String
  siret              String?
  address            String
  activitiesJson     String?
  /// Activités / travaux exclus du périmètre couvert (libellés, JSON string[])
  exclusionsJson     String?
  projectName        String?
  projectAddress     String?
  constructionNature String?
  premium            Float
  status             String
  paidAt             DateTime?
  validFrom          DateTime?
  validUntil         DateTime?
  insurerValidatedAt DateTime?
  riskScore          Int?
  rejectedReason     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  storedDocuments    ContractStoredDocument[]
  lifecyclePayments  ContractLifecyclePayment[]
  actionLogs         ContractActionLog[]
}

model ContractStoredDocument {
  id         String            @id @default(cuid())
  contractId String
  contract   InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type       String
  url        String
  createdAt  DateTime          @default(now())

  @@unique([contractId, type])
}

model ContractLifecyclePayment {
  id              String            @id @default(cuid())
  contractId      String
  contract        InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  molliePaymentId String            @unique
  amount          Float
  status          String
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
}

model ContractActionLog {
  id         String            @id @default(cuid())
  contractId String
  contract   InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  action     String
  details    String?
  actorEmail String?
  createdAt  DateTime          @default(now())
}

/// Abonnement prélèvements SEPA trimestriels (T2–T4) après 1er trimestre CB — Mollie Customer + mandate.
model SepaSubscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mollieCustomerId    String
  mollieMandateId     String?
  primeAnnuelle       Float
  /// Nombre de prélèvements SEPA déjà réussis (0 à 3)
  trimestresSepaPayes Int       @default(0)
  /// Date du 1er trimestre payé par carte (référence calendrier)
  firstTrimesterPaidAt DateTime?
  /// Prochaine échéance SEPA à traiter
  nextSepaDue         DateTime?
  status              String    @default("active") // active | completed | pending_mandate | failed | cancelled
  lastError           String?
  /// Prélèvement SEPA lancé, en attente du webhook Mollie (évite un doublon si le cron repasse)
  sepaPendingPaymentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // kbis | piece_identite | ... | releve_sinistralite | ...
  filename  String
  filepath  String   // chemin relatif sur le serveur
  mimeType  String
  size      Int      // octets
  createdAt DateTime @default(now())
  sinistres Sinistre[]

  @@unique([userId, type])
}

model Sinistre {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDocumentId   String?       // relevé de sinistralité auquel ce sinistre est lié
  userDocument     UserDocument? @relation(fields: [userDocumentId], references: [id], onDelete: SetNull)
  dateSinistre     DateTime
  montantIndemnisation Float?
  description      String?
  createdAt        DateTime      @default(now())
}

model Document {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 String               // "devis" | "contrat" | "attestation" | "avenant"
  numero               String               @unique
  data                 String               // JSON des données du document
  verificationToken    String?              @unique // pour QR code attestation
  status               String               @default("valide") // "valide" | "perimee" | "suspendu" | "resilie"
  createdAt            DateTime             @default(now())
  resiliationLogs      ResiliationLog[]
  resiliationRequests  ResiliationRequest[]
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  molliePaymentId String  @unique
  amount          Float
  status          String   // "paid" | "pending" | "failed"
  paidAt          DateTime?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
}

model AvenantFee {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  amount     Float     @default(60)
  status     String    @default("pending")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
}

model DevisLead {
  id            String   @id @default(cuid())
  email         String
  raisonSociale String?
  siret         String?
  primeAnnuelle Float?
  rappelSentAt  DateTime?
  createdAt     DateTime @default(now())
}

model DevisEtudeLead {
  id            String   @id @default(cuid())
  email         String
  raisonSociale String?
  siret         String?
  data          String   // JSON : chiffreAffaires, sinistres, activites, etc.
  statut        String   @default("pending") // pending | mise_envoyee | cloture
  primeProposee Float?   // prime personnalisée envoyée au client
  miseEnvoyeeAt DateTime?
  createdAt     DateTime @default(now())
}

model DevisDommageOuvrageLead {
  id        String   @id @default(cuid())
  email     String
  data      String   // JSON du questionnaire
  coutTotal Float?
  createdAt DateTime @default(now())
}

model PendingSignature {
  id                 String   @id @default(cuid())
  signatureRequestId String   @unique // UUID sign_requests (Supabase Sign)
  userId             String
  contractData       String   // JSON du contrat
  contractNumero     String
  createdAt          DateTime @default(now())
}

model DevoirConseilLog {
  id         String   @id @default(cuid())
  email      String?
  userId     String?
  page       String   // souscription | signature | formulaire_do | paiement_do
  produit    String   // decennale | dommage-ouvrage
  acceptedAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ResiliationLog {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  adminEmail String
  motif      String?
  createdAt  DateTime @default(now())
}

model ResiliationRequest {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  motif      String?
  status     String   @default("pending") // pending | approved | rejected
  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime @default(now())
}

model DevisDraft {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  data      String   // JSON du devis en cours
  produit   String   @default("decennale") // decennale | dommage-ouvrage
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ClientNote {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String
  adminEmail String
  createdAt  DateTime @default(now())
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  targetType String?  // user | document | payment | ...
  targetId   String?
  details    String?  // JSON
  createdAt  DateTime @default(now())
}

/// Compteur séquentiel par année et produit pour numéros OPT-DEC-YYYY-NNNN / OPT-DO-YYYY-NNNN
model ContractCounter {
  year    Int
  product String
  lastSeq Int    @default(0)
  @@id([year, product])
}

/// Journal des PDF générés via /api/pdf/*
model PdfGenerationLog {
  id             String   @id @default(cuid())
  contractNumber String
  productType    String
  documentType   String
  userId         String?
  generatedAt    DateTime @default(now())
  metadata       String?
}
