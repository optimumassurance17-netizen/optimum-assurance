generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  passwordHash          String
  raisonSociale         String?
  siret                String?
  adresse               String?
  codePostal            String?
  ville                 String?
  telephone             String?
  /// Premier questionnaire DO (devis public) — JSON, pour préremplir le questionnaire d’étude espace client
  doInitialQuestionnaireJson String?           @db.Text
  /// Questionnaire d’étude DO complété depuis l’espace client — JSON
  doEtudeQuestionnaireJson   String?           @db.Text
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  documents             Document[]
  userDocuments         UserDocument[]
  payments              Payment[]
  avenantFees           AvenantFee[]
  passwordResetTokens   PasswordResetToken[]
  resiliationRequests   ResiliationRequest[]
  clientNotes           ClientNote[]
  sinistres             Sinistre[]
  missingSubActivities  MissingSubActivity[]
  sepaSubscription      SepaSubscription?
  insuranceContracts    InsuranceContract[]
  missingActivities     MissingActivity[]
}

/// Nomenclature interne des activités BTP (référentiel France Assureurs 2019)
model Activity {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  definition         String   @db.Text
  includedWorks      String   @db.Text // JSON string[]
  excludedWorks      String   @db.Text // JSON string[]
  relatedActivities  String   @db.Text // JSON string[]
  isAccessoryAllowed Boolean  @default(false)
  version            String   @default("france-assureurs-2019")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Activités saisies non reconnues pour revue nomenclature (amélioration continue)
model MissingActivity {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userInput     String
  suggestedMatch String?
  date          DateTime @default(now())
  validated     Boolean  @default(false)
  occurrenceCount Int    @default(1)
  lastSeenAt    DateTime @default(now())

  @@index([userInput])
  @@index([validated, date])
  @@index([suggestedMatch])
}

/// Cycle de vie assurance (plateforme SaaS — décennale | DO). DB : PostgreSQL (URL Supabase possible).
model InsuranceContract {
  id                 String   @id @default(cuid())
  contractNumber     String   @unique
  userId             String?
  user               User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  productType        String
  clientName         String
  siret              String?
  address            String
  activitiesJson     String?
  /// Activités / travaux exclus du périmètre couvert (libellés, JSON string[])
  exclusionsJson     String?
  projectName        String?
  projectAddress     String?
  constructionNature String?
  premium            Float
  status             String
  paidAt             DateTime?
  validFrom          DateTime?
  validUntil         DateTime?
  insurerValidatedAt DateTime?
  riskScore          Int?
  rejectedReason     String?
  /// Devis / proposition PDF signé (bucket « signed » Supabase e-sign), clé objet — produits type rc_fabriquant
  signedQuoteStorageKey String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  storedDocuments    ContractStoredDocument[]
  lifecyclePayments  ContractLifecyclePayment[]
  actionLogs         ContractActionLog[]
}

model ContractStoredDocument {
  id         String            @id @default(cuid())
  contractId String
  contract   InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  type       String
  url        String
  createdAt  DateTime          @default(now())

  @@unique([contractId, type])
}

model ContractLifecyclePayment {
  id              String            @id @default(cuid())
  contractId      String
  contract        InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  molliePaymentId String            @unique
  amount          Float
  status          String
  paidAt          DateTime?
  createdAt       DateTime          @default(now())
}

model ContractActionLog {
  id         String            @id @default(cuid())
  contractId String
  contract   InsuranceContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  action     String
  details    String?
  actorEmail String?
  createdAt  DateTime          @default(now())
}

/// Abonnement prélèvements SEPA trimestriels après 1er trimestre CB — reconduction automatique annuelle.
model SepaSubscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mollieCustomerId    String
  mollieMandateId     String?
  primeAnnuelle       Float
  /// Nombre total de prélèvements SEPA déjà réussis
  trimestresSepaPayes Int       @default(0)
  /// Date du 1er trimestre payé par carte (référence calendrier)
  firstTrimesterPaidAt DateTime?
  /// Prochaine échéance SEPA à traiter
  nextSepaDue         DateTime?
  status              String    @default("active") // active | completed(legacy) | pending_mandate | failed | cancelled
  lastError           String?
  /// Prélèvement SEPA lancé, en attente du webhook Mollie (évite un doublon si le cron repasse)
  sepaPendingPaymentId String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UserDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // kbis | piece_identite | ... | releve_sinistralite | ...
  filename  String
  filepath  String   // chemin relatif sur le serveur
  mimeType  String
  size      Int      // octets
  createdAt DateTime @default(now())
  sinistres Sinistre[]

  @@unique([userId, type])
}

model Sinistre {
  id               String        @id @default(cuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userDocumentId   String?       // relevé de sinistralité auquel ce sinistre est lié
  userDocument     UserDocument? @relation(fields: [userDocumentId], references: [id], onDelete: SetNull)
  dateSinistre     DateTime
  montantIndemnisation Float?
  description      String?
  createdAt        DateTime      @default(now())
}

model ActivityGroup {
  id          String     @id @default(cuid())
  code        String     @unique
  name        String
  definition  String?    @db.Text
  version     String     @default("france-assureurs-2019")
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
}

model Activity {
  id                String        @id @default(cuid())
  groupId           String
  group             ActivityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupCode         String
  code              String        @unique
  name              String
  definition        String        @db.Text
  includedWorks     String?       @db.Text
  excludedWorks     String?       @db.Text
  relatedActivities String?       @db.Text
  isAccessoryAllowed Boolean      @default(false)
  version           String        @default("france-assureurs-2019")
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  subActivities     SubActivity[]

  @@index([groupId])
  @@index([groupCode])
}

model SubActivity {
  id                String   @id @default(cuid())
  activityId        String
  activity          Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  groupCode         String
  activityCode      String
  code              String   @unique
  name              String
  description       String   @db.Text
  includedWorks     String?  @db.Text
  excludedWorks     String?  @db.Text
  relatedActivities String?  @db.Text
  version           String   @default("france-assureurs-2019")
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([activityId])
  @@index([groupCode])
  @@index([activityCode])
}

model MissingSubActivity {
  id                     String   @id @default(cuid())
  userId                 String?
  user                   User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userInput              String
  suggestedGroupCode     String?
  suggestedGroupName     String?
  suggestedActivityCode  String?
  suggestedActivityName  String?
  suggestedSubActivityCode String?
  suggestedSubActivityName String?
  confidence             Float?
  validated              Boolean  @default(false)
  occurrenceCount        Int      @default(1)
  createdAt              DateTime @default(now())
  lastSeenAt             DateTime @default(now())

  @@index([userInput])
  @@unique([userId, userInput], map: "missing_sub_activity_user_input_unique")
}

model Document {
  id                   String               @id @default(cuid())
  userId               String
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type                 String               // "devis" | "contrat" | "attestation" | "avenant"
  numero               String               @unique
  data                 String               // JSON des données du document
  verificationToken    String?              @unique // pour QR code attestation
  status               String               @default("valide") // "valide" | "perimee" | "suspendu" | "resilie"
  createdAt            DateTime             @default(now())
  resiliationLogs      ResiliationLog[]
  resiliationRequests  ResiliationRequest[]
}

model Payment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  molliePaymentId String  @unique
  amount          Float
  status          String   // "paid" | "pending" | "failed"
  paidAt          DateTime?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())
}

model AvenantFee {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId String
  amount     Float     @default(60)
  status     String    @default("pending")
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
}

model DevisLead {
  id            String   @id @default(cuid())
  email         String
  raisonSociale String?
  siret         String?
  primeAnnuelle Float?
  rappelSentAt  DateTime?
  createdAt     DateTime @default(now())
}

model DevisEtudeLead {
  id            String   @id @default(cuid())
  email         String
  raisonSociale String?
  siret         String?
  data          String   // JSON : chiffreAffaires, sinistres, activites, etc.
  statut        String   @default("pending") // pending | mise_envoyee | cloture
  primeProposee Float?   // prime personnalisée envoyée au client
  miseEnvoyeeAt DateTime?
  createdAt     DateTime @default(now())
}

model DevisDommageOuvrageLead {
  id        String   @id @default(cuid())
  email     String
  data      String   // JSON du questionnaire
  coutTotal Float?
  createdAt DateTime @default(now())
}

/// Demande de devis RC Fabriquant (étude manuelle, pas de tarif auto sur le site).
model DevisRcFabriquantLead {
  id              String   @id @default(cuid())
  email           String
  data            String // JSON : raisonSociale, siret, activiteFabrication, etc.
  /// Suivi interne : a_traiter | en_cours | proposition_envoyee | refuse | clos
  statut                String    @default("a_traiter")
  notesInternes         String?   @db.Text
  /// Dernière prime annuelle indiquée dans l’e-mail de proposition (à titre indicatif)
  primeProposee         Float?
  propositionEnvoyeeAt  DateTime?
  /// Dernière interaction WhatsApp tracée (clic CTA)
  lastWhatsappClickAt   DateTime?
  lastWhatsappSource    String?
  lastWhatsappRef       String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model PendingSignature {
  id                 String   @id @default(cuid())
  signatureRequestId String   @unique // UUID sign_requests (Supabase Sign)
  userId             String
  contractData       String   // JSON du contrat
  contractNumero     String
  createdAt          DateTime @default(now())
}

model DevoirConseilLog {
  id         String   @id @default(cuid())
  email      String?
  userId     String?
  page       String   // souscription | signature | formulaire_do | paiement_do
  produit    String   // decennale | dommage-ouvrage
  acceptedAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ResiliationLog {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  adminEmail String
  motif      String?
  createdAt  DateTime @default(now())
}

model ResiliationRequest {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  motif      String?
  status     String   @default("pending") // pending | approved | rejected
  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime @default(now())
}

model DevisDraft {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  data      String   // JSON du devis en cours
  produit   String   @default("decennale") // decennale | dommage-ouvrage
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ClientNote {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    String
  adminEmail String
  createdAt  DateTime @default(now())
}

model AdminActivityLog {
  id         String   @id @default(cuid())
  adminEmail String
  action     String
  targetType String?  // user | document | payment | ...
  targetId   String?
  details    String?  // JSON
  createdAt  DateTime @default(now())
}

/// Historique des clics sortants vers WhatsApp (source, message et contexte CRM éventuel).
model WhatsappClickLog {
  id         String   @id @default(cuid())
  target     String
  source     String
  text       String?
  reference  String?
  leadType   String?
  leadId     String?
  userId     String?
  userEmail  String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
}

/// Compteur séquentiel par année et produit pour numéros OPT-DEC-YYYY-NNNN / OPT-DO-YYYY-NNNN
model ContractCounter {
  year    Int
  product String
  lastSeq Int    @default(0)
  @@id([year, product])
}

/// Journal des PDF générés via /api/pdf/*
model PdfGenerationLog {
  id             String   @id @default(cuid())
  contractNumber String
  productType    String
  documentType   String
  userId         String?
  generatedAt    DateTime @default(now())
  metadata       String?
}
