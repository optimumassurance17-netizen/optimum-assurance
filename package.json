{
  "name": "optimum-assurance",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "ios_saf >= 16.4",
    "not dead"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:setup": "node scripts/dev-setup.mjs",
    "build": "prisma generate && next build",
    "analyze": "cross-env ANALYZE=true prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "preflight": "node scripts/preflight.mjs",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "generate-secret": "node scripts/generate-secret.mjs",
    "secrets:prod": "node scripts/secrets-prod.mjs",
    "check-env": "node scripts/check-env.mjs",
    "create-admin": "node scripts/create-admin-user.mjs",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "vercel:import": "node scripts/import-vercel-env.mjs",
    "vercel:db-push": "node scripts/db-push-vercel.mjs",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel"
  },
  "dependencies": {
    "@mollie/api-client": "^4.4.0",
    "@prisma/client": "5.22.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/supabase-js": "^2.100.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.1",
    "next-auth": "^4.24.0",
    "openai": "^6.27.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "prisma": "5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^50.37.3"
  }
}
