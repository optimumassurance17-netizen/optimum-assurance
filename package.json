{
  "name": "optimum-assurance",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4",
    "ios_saf >= 16.4",
    "not dead"
  ],
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "dev:setup": "node scripts/dev-setup.mjs",
    "build": "prisma generate && next build",
    "analyze": "cross-env ANALYZE=true prisma generate && next build",
    "vercel-build": "prisma generate && next build",
    "preflight": "node scripts/preflight.mjs",
    "verify:prod": "node scripts/verify-prod-remote.mjs",
    "print:webhooks": "node scripts/print-webhook-urls.mjs",
    "print:crons": "node scripts/print-crons.mjs",
    "print:post-launch": "node scripts/print-post-launch.mjs",
    "start": "next start",
    "lint": "eslint",
    "check:boundaries": "node scripts/check-client-server-boundaries.mjs",
    "typecheck": "tsc --noEmit",
    "test:pdf-contractual": "tsx scripts/verify-pdf-contractual-mentions.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:seed-admin": "node scripts/seed-e2e-admin.mjs",
    "db:push": "prisma db push",
    "db:sync-url-vercel": "node scripts/sync-database-url-from-vercel-pull.mjs",
    "db:migrate:prod": "node scripts/prisma-migrate-prod.mjs",
    "db:repair:exclusions": "node scripts/prisma-repair-exclusions-flow.mjs",
    "db:sync:prod": "node scripts/prisma-sync-prod-schema.mjs",
    "db:generate": "prisma generate",
    "generate-secret": "node scripts/generate-secret.mjs",
    "secrets:prod": "node scripts/secrets-prod.mjs",
    "check-env": "node scripts/check-env.mjs",
    "audit:env": "node scripts/audit-env-files.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "print:supabase-signature": "node scripts/print-supabase-signature-activation.mjs",
    "supabase:apply-esign-sql": "node scripts/apply-supabase-esign-sql.mjs",
    "supabase:install": "node scripts/supabase-install-all.mjs",
    "supabase:bundle": "node scripts/bundle-supabase-sql.mjs",
    "supabase:apply-rls-sql": "node scripts/apply-supabase-rls-sql.mjs",
    "supabase:apply-esign-policies": "node scripts/apply-supabase-esign-policies.mjs",
    "supabase:touch-migration": "node scripts/supabase-touch-migration.mjs",
    "vercel:push-supabase-env": "node scripts/vercel-push-supabase-env.mjs",
    "verify:vercel-env": "node scripts/verify-vercel-env.mjs",
    "verify:release": "npm run verify:vercel-env && npm run verify:prod",
    "verify:all": "node scripts/verify-all.mjs",
    "seo:bulk": "tsx scripts/seo-bulk-generate.ts",
    "seo:benchmark": "node scripts/seo-benchmark.mjs",
    "seo:ai": "tsx scripts/generate-ai-content.ts",
    "create-admin": "node scripts/create-admin-user.mjs",
    "icons:pwa": "node scripts/generate-pwa-icons.mjs",
    "extract:cg-do": "node scripts/extract-cg-do.mjs",
    "vercel:import": "node scripts/import-vercel-env.mjs",
    "vercel:db-push": "node scripts/db-push-vercel.mjs",
    "deploy": "vercel --prod",
    "deploy:preview": "vercel",
    "esign:create-request": "node scripts/esign-create-request.mjs",
    "skills:supabase": "npx skills add supabase/agent-skills --yes"
  },
  "dependencies": {
    "@mollie/api-client": "^4.4.0",
    "@prisma/client": "5.22.0",
    "@react-pdf/renderer": "^4.3.2",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "next": "^16.2.1",
    "next-auth": "^4.24.0",
    "openai": "^6.27.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-signature-canvas": "^1.0.7",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.1",
    "pdf-parse": "^1.1.1",
    "prisma": "5.22.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^50.39.0"
  },
  "overrides": {
    "tar": "7.5.13",
    "@tootallnate/once": "3.0.1",
    "undici": "6.24.1",
    "minimatch": "10.2.5",
    "smol-toml": "1.6.1",
    "srvx": "0.11.15",
    "path-to-regexp": "8.4.2",
    "@vercel/node": {
      "path-to-regexp": "6.3.0"
    },
    "@vercel/static-config": {
      "ajv": "8.18.0"
    }
  }
}
