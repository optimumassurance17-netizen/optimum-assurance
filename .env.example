# Optimum Assurance - Variables d'environnement
# 1. Copier ce fichier vers .env
# 2. npm run generate-secret → copier NEXTAUTH_SECRET
# 3. Renseigner les clés API (Mollie, Resend, Yousign)
# 4. npm run secrets:prod → génère NEXTAUTH_SECRET, CRON_SECRET, YOUSIGN_WEBHOOK_SECRET (à copier dans Vercel)
# 5. npm run preflight (ou npm run check-env) pour vérifier
#
# --- Vercel (production) ---
# Build Command : npm run vercel-build  (prisma generate + next build — pas de migrate au build)
# Migrations : npx prisma migrate deploy sur la BDD prod (voir DEPLOY.md)

# Mollie - Paiements en ligne (test_ pour sandbox, live_ pour prod)
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxx

# URL de base (obligatoire pour liens emails, callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mentions légales (affichées sur /mentions-legales — remplir en production)
# NEXT_PUBLIC_LEGAL_COMPANY_ADDRESS=12 rue Exemple, 75001 Paris
# NEXT_PUBLIC_LEGAL_RCS_CITY=Paris
# NEXT_PUBLIC_LEGAL_SIRET=123 456 789 00012
# NEXT_PUBLIC_ORIAS_NUMBER=12 34 56 78

# SEO — URL canonique (recommandé en prod, alignée sur le domaine public)
# NEXT_PUBLIC_SITE_CANONICAL=https://www.optimum-assurance.fr

# SEO - Google Search Console (optionnel)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=votre_code_verification
# Profils sociaux pour schema.org sameAs (séparés par virgule ou espace)
# NEXT_PUBLIC_SEO_SAME_AS=https://www.linkedin.com/company/...,https://www.facebook.com/...

# Avis - Liens vers Google Avis et Trustpilot (optionnel)
# NEXT_PUBLIC_GOOGLE_REVIEWS_URL=https://g.page/r/xxx/review
# NEXT_PUBLIC_TRUSTPILOT_URL=https://www.trustpilot.com/review/optimum-assurance.fr

# Contact - affiché sur le site (footer, formulaire, etc.)
NEXT_PUBLIC_EMAIL=contact@optimum-assurance.fr
# Adresse de réception du formulaire de contact (défaut: NEXT_PUBLIC_EMAIL)
CONTACT_EMAIL=contact@optimum-assurance.fr

# Base de données PostgreSQL (obligatoire)
# Local : docker compose up -d puis postgresql://postgres:postgres@localhost:5432/optimum
# Prod : Vercel Postgres, Supabase, Neon, Railway...
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/optimum"

# NextAuth - obligatoire
NEXTAUTH_URL=http://localhost:3000
# Générer avec: npm run generate-secret
NEXTAUTH_SECRET=changez-moi-en-production

# Gestion CRM - emails ayant accès à /gestion (séparés par des virgules)
ADMIN_EMAILS=admin@example.com

# Pré-remplissage SIRET - API Sirene INSEE (gratuit) ou Pappers (payant)
# INSEE : portail-api.insee.fr → créer app → Sirene V3 → générer clés
INSEE_API_KEY_INTEGRATION=
# Ou OAuth2 : INSEE_CONSUMER_KEY + INSEE_CONSUMER_SECRET
# INSEE_CONSUMER_KEY=
# INSEE_CONSUMER_SECRET=
# Pappers (fallback) : api.pappers.fr
PAPPERS_API_KEY=

# Envoi d'emails - Resend (obligatoire pour confirmations, devis DO, formulaire contact)
# Créer un compte sur resend.com, vérifier le domaine
RESEND_API_KEY=
EMAIL_FROM=Optimum <noreply@votredomaine.com>

# IA - Chatbot (optionnel : sans clé, le chatbot utilise la FAQ)
OPENAI_API_KEY=

# Signature électronique Yousign (sandbox pour dev, production pour prod)
YOUSIGN_API_KEY=
YOUSIGN_ENV=sandbox
# Secret webhook YouSign (dashboard YouSign → abonnement webhook)
YOUSIGN_WEBHOOK_SECRET=

# Crons Vercel - rappels renouvellement, devis abandonné (Bearer token)
# Générer avec: npm run generate-secret
CRON_SECRET=

# Supabase — signature MVP (/api/sign, Storage) — optionnel si non utilisé
# Créer un projet sur supabase.com, exécuter sql/supabase-esign-complete.sql (ou npm run supabase:apply-esign-sql)
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (jamais côté client — serveur uniquement)
# URI Postgres du projet (pour apply SQL en CLI — pas Neon) :
# SUPABASE_DATABASE_URL=postgresql://postgres....
