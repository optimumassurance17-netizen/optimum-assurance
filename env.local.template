# Copier vers .env.local (ou fusionner avec .env).
# Next.js charge .env puis .env.local (les clés de .env.local priment).
# Liste complète et commentaires : voir .env.example

NEXT_PUBLIC_APP_URL=http://localhost:3000
# Test Mollie en local : URL HTTPS ngrok (prioritaire pour webhooks Mollie si défini)
# MOLLIE_PUBLIC_BASE_URL=https://xxxx.ngrok-free.app
NEXTAUTH_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Alternative dashboard (clé « publishable » / anon) :
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
# Lecture / build ISR (pages SEO programmatiques). Ne jamais exposer au client.
# Sur Vercel : intégration Supabase (marketplace) + ajout manuel de SUPABASE_SERVICE_ROLE_KEY — voir DEPLOY.md §2.
SUPABASE_SERVICE_ROLE_KEY=
# MVP signature /sign/[id] : exécuter sql/supabase-esign-mvp.sql puis sql/supabase-esign-storage.sql ; puis npm run esign:create-request -- chemin/vers.pdf
# Injection bulk SEO : npm run seo:bulk (même URL + clé service role pour INSERT)
# Génération SEO IA : npm run seo:ai (OPENAI_API_KEY obligatoire ; OPENAI_MODEL optionnel gpt-4o / gpt-4o-mini)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_LIMIT_PER_RUN=5
AI_DELAY_MS=1200
MOLLIE_API_KEY=
# Alertes email à chaque demande de devis (liste séparée par virgules). Sinon : ADMIN_EMAILS, puis CONTACT_EMAIL / NEXT_PUBLIC_EMAIL.
# DEVIS_ALERT_EMAILS=courtier@example.com
